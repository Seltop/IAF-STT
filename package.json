{
  "name": "hebrew-stt-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"tsx watch server/index.ts\"",
    "local:stt": "powershell -NoProfile -ExecutionPolicy Bypass -File local-stt/start-native.ps1",
    "local:stt:docker": "docker compose -f local-stt/docker-compose.yml up --build",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist-server/server/index.js",
    "preview": "node dist-server/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
