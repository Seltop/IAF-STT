STT_PROVIDER=soniox
SONIOX_API_KEY=replace-with-soniox-api-key
SONIOX_MODEL=stt-rt-v5
SONIOX_MAX_ENDPOINT_DELAY_MS=2000
SONIOX_WS_URL=wss://stt-rt.soniox.com/transcribe-websocket

# Local AI mode is available from the UI switch. The default native Python
# sidecar runs on NVIDIA GPU when available and falls back to CPU if CUDA fails.
LOCAL_STT_WS_URL=ws://127.0.0.1:8011/ws
LOCAL_STT_ENGINE=faster_whisper
LOCAL_STT_FASTER_WHISPER_MODEL=ivrit-ai/whisper-large-v3-turbo-ct2
LOCAL_STT_DEVICE=cuda
LOCAL_STT_COMPUTE_TYPE=float16
LOCAL_STT_MODEL=OzLabs/Caspi-1.7B
LOCAL_STT_LANGUAGE=Hebrew
LOCAL_STT_GPU_MEMORY_UTILIZATION=0.9
LOCAL_STT_CONFIRMATION_ENABLED=true
LOCAL_STT_STABLE_WORD_LAG=0
LOCAL_STT_MIN_COMMIT_INTERVAL_MS=600
LOCAL_STT_MAX_NEW_TOKENS=32

# Optional: switch STT_PROVIDER=azure to compare against Azure Speech.
AZURE_SPEECH_KEY=replace-with-azure-speech-key
AZURE_SPEECH_REGION=replace-with-azure-region

PORT=8787
MAX_CHANNELS=4

# Optional: set to /stt when deploying behind a domain path such as https://seltop.work/stt.
PUBLIC_BASE_PATH=
