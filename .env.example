STT_PROVIDER=soniox
SONIOX_API_KEY=replace-with-soniox-api-key
SONIOX_MODEL=stt-rt-v5
SONIOX_MAX_ENDPOINT_DELAY_MS=2000
SONIOX_WS_URL=wss://stt-rt.soniox.com/transcribe-websocket

# Optional: switch STT_PROVIDER=azure to compare against Azure Speech.
AZURE_SPEECH_KEY=replace-with-azure-speech-key
AZURE_SPEECH_REGION=replace-with-azure-region

PORT=8787
MAX_CHANNELS=4

# Optional: set to /stt when deploying behind a domain path such as https://seltop.work/stt.
PUBLIC_BASE_PATH=
